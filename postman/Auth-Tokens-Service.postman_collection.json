{
	"info": {
		"name": "Auth Tokens Service",
		"description": "JWT authentication microservice with Google OAuth 2.0 support",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "auth-tokens-v1"
	},
	"item": [
		{
			"name": "Health & Info",
			"item": [
				{
					"name": "Root - Service Info",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{auth_base_url}}/",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								""
							]
						},
						"description": "Get basic service information"
					}
				},
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{auth_base_url}}/health",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"health"
							]
						},
						"description": "Check if the service is healthy"
					}
				},
				{
					"name": "Detailed Info",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{auth_base_url}}/info",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"info"
							]
						},
						"description": "Get detailed service information"
					}
				}
			]
		},
		{
			"name": "Traditional Authentication",
			"item": [
				{
					"name": "Create Token (Username/Password)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('access_token', response.access_token);",
									"    console.log('Access token saved to environment');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpass123\"\n}"
						},
						"url": {
							"raw": "{{auth_base_url}}/api/v1/tokens",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"api",
								"v1",
								"tokens"
							]
						},
						"description": "Create JWT token using username and password"
					}
				},
				{
					"name": "Create Token (OAuth2 Format)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('access_token', response.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "password",
									"type": "text"
								},
								{
									"key": "username",
									"value": "testuser",
									"type": "text"
								},
								{
									"key": "password",
									"value": "testpass123",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{auth_base_url}}/api/v1/tokens/oauth",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"api",
								"v1",
								"tokens",
								"oauth"
							]
						},
						"description": "OAuth2-compatible token endpoint with form-urlencoded format"
					}
				},
				{
					"name": "Validate Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{access_token}}\"\n}"
						},
						"url": {
							"raw": "{{auth_base_url}}/api/v1/validate",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"api",
								"v1",
								"validate"
							]
						},
						"description": "Validate a JWT token and get user information"
					}
				}
			]
		},
		{
			"name": "Google OAuth",
			"item": [
				{
					"name": "Authenticate with Google Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('access_token', response.access_token);",
									"    console.log('Google OAuth token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id_token\": \"{{google_id_token}}\"\n}"
						},
						"url": {
							"raw": "{{auth_base_url}}/api/v1/auth/google/token",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"google",
								"token"
							]
						},
						"description": "Authenticate using Google ID token. Returns internal JWT access token.\n\nFlow:\n1. User signs in with Google on frontend\n2. Frontend receives Google ID token\n3. Send ID token to this endpoint\n4. Receive internal JWT for your app\n\nResponse includes:\n- access_token: Your internal JWT\n- user: User profile with Google data"
					}
				}
			]
		},
		{
			"name": "Testing Endpoints",
			"item": [
				{
					"name": "Generate Mock Google Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('google_id_token', response.id_token);",
									"    console.log('Mock Google token generated and saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test.user@gmail.com\",\n  \"name\": \"Test User\",\n  \"picture\": \"https://lh3.googleusercontent.com/a/default-user\",\n  \"email_verified\": true\n}"
						},
						"url": {
							"raw": "{{auth_base_url}}/test/mock/google/token",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"test",
								"mock",
								"google",
								"token"
							]
						},
						"description": "Generate a mock Google ID token for testing without real Google credentials.\n\nThis is useful for:\n- Local development\n- Testing the Google OAuth flow\n- CI/CD pipelines\n\nThe generated token can be used with the 'Authenticate with Google Token' endpoint."
					}
				}
			]
		},
		{
			"name": "Complete Google OAuth Flow (Test)",
			"item": [
				{
					"name": "Step 1: Generate Mock Google Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('google_id_token', response.id_token);",
									"    console.log('✅ Step 1 Complete: Mock token generated');",
									"    console.log('Next: Run Step 2 to authenticate');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"alice.demo@gmail.com\",\n  \"name\": \"Alice Demo User\",\n  \"picture\": \"https://lh3.googleusercontent.com/alice\",\n  \"email_verified\": true\n}"
						},
						"url": {
							"raw": "{{auth_base_url}}/test/mock/google/token",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"test",
								"mock",
								"google",
								"token"
							]
						},
						"description": "STEP 1: Generate a mock Google token.\nThis saves the token to {{google_id_token}} variable."
					}
				},
				{
					"name": "Step 2: Authenticate with Google",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('access_token', response.access_token);",
									"    console.log('✅ Step 2 Complete: User authenticated');",
									"    console.log('User ID:', response.user.user_id);",
									"    console.log('Next: Run Step 3 to validate token');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id_token\": \"{{google_id_token}}\"\n}"
						},
						"url": {
							"raw": "{{auth_base_url}}/api/v1/auth/google/token",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"google",
								"token"
							]
						},
						"description": "STEP 2: Authenticate using the Google token from Step 1.\nThis creates/links the user and returns your internal JWT."
					}
				},
				{
					"name": "Step 3: Validate Internal JWT",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    console.log('✅ Step 3 Complete: Token validated');",
									"    console.log('🎉 Google OAuth flow successful!');",
									"    console.log('User:', response.username);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{access_token}}\"\n}"
						},
						"url": {
							"raw": "{{auth_base_url}}/api/v1/validate",
							"host": [
								"{{auth_base_url}}"
							],
							"path": [
								"api",
								"v1",
								"validate"
							]
						},
						"description": "STEP 3: Validate the internal JWT token.\nThis confirms the complete OAuth flow worked correctly."
					}
				}
			],
			"description": "Complete end-to-end test of Google OAuth flow.\n\nRun these requests in order:\n1. Generate mock Google token\n2. Authenticate with Google\n3. Validate internal JWT\n\nEach step saves variables for the next step automatically."
		}
	],
	"variable": [
		{
			"key": "auth_base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "google_id_token",
			"value": "",
			"type": "string"
		}
	]
}
