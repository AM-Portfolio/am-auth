                {
                        "name": "User Authentication",
                        "item": [
                                {
                                        "name": "Register New User",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    pm.environment.set('user_id', response.user_id);",
                                                                        "    console.log('User registered:', response.email);",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "method": "POST",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"email\": \"newuser.{{$timestamp}}@example.com\",\n  \"password\": \"SecurePassword123!\",\n  \"phone_number\": \"+1{{$randomInt}}\"\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/auth/register",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "auth",
                                                                "register"
                                                        ]
                                                },
                                                "description": "Register a new user with email, password, and phone number.\n\nUses random values to ensure uniqueness."
                                        }
                                },
                                {
                                        "name": "Login (Validate Credentials)",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    pm.environment.set('user_id', response.user_id);",
                                                                        "    console.log('Login successful:', response.username);",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "method": "POST",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/auth/login",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "auth",
                                                                "login"
                                                        ]
                                                },
                                                "description": "Validate user credentials and return user data.\n\nThis endpoint is typically called by the Auth Tokens service.\n\nReturns:\n- user_id\n- username\n- email\n- status\n- scopes"
                                        }
                                }
                        ]
                },
                {
                        "name": "User Status Management",
                        "item": [
                                {
                                        "name": "Get User Status by ID",
                                        "request": {
                                                "method": "GET",
                                                "header": [],
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/users/{{user_id}}/status",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "users",
                                                                "{{user_id}}",
                                                                "status"
                                                        ]
                                                },
                                                "description": "Get user status and details by user ID (UUID).\n\nReturns:\n- user_id\n- email\n- status (active, inactive, pending_verification, suspended, deleted)\n- email_verified\n- auth_provider\n- timestamps (created_at, last_login_at, verified_at, locked_until)\n- failed_login_attempts"
                                        }
                                },
                                {
                                        "name": "Get User Status by Email",
                                        "request": {
                                                "method": "GET",
                                                "header": [],
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/users/email/{{user_email}}/status",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "users",
                                                                "email",
                                                                "{{user_email}}",
                                                                "status"
                                                        ]
                                                },
                                                "description": "Get user status and details by email address.\n\nProvide email in {{user_email}} variable or replace in URL.\n\nReturns complete user status information."
                                        }
                                },
                                {
                                        "name": "Update User Status by ID",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    console.log('Status updated from', response.old_status, 'to', response.new_status);",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "method": "PATCH",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"status\": \"active\",\n  \"reason\": \"Email verification completed\"\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/users/{{user_id}}/status",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "users",
                                                                "{{user_id}}",
                                                                "status"
                                                        ]
                                                },
                                                "description": "Update user status by user ID.\n\nValid status values:\n- active: User can login\n- inactive: User deactivated\n- pending_verification: Awaiting verification\n- suspended: Temporarily suspended\n- deleted: Marked as deleted\n\nOptional 'reason' field for audit trail."
                                        }
                                },
                                {
                                        "name": "Update User Status by Email",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    console.log('Status updated from', response.old_status, 'to', response.new_status);",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "method": "PATCH",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"status\": \"suspended\",\n  \"reason\": \"Policy violation - spam activity detected\"\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/users/email/{{user_email}}/status",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "users",
                                                                "email",
                                                                "{{user_email}}",
                                                                "status"
                                                        ]
                                                },
                                                "description": "Update user status by email address.\n\nValid status values:\n- active\n- inactive\n- pending_verification\n- suspended\n- deleted\n\nOptional 'reason' for audit purposes."
                                        }
                                }
                        ],
                        "description": "Endpoints to check and manage user account status.\n\nUse these to:\n- Check user verification/active status\n- Activate users after email verification\n- Suspend/delete user accounts\n- Track user account lifecycle"
                },
                {
                        "name": "Google OAuth",
                        "item": [
                                {
                                        "name": "Create/Link Google User",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    pm.environment.set('user_id', response.user_id);",
                                                                        "    console.log('Google user created/linked:', response.username);",
                                                                        "    console.log('Is new user:', response.is_new_user);",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "method": "POST",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"google_id\": \"{{$randomInt}}\",\n  \"email\": \"google.user.{{$timestamp}}@gmail.com\",\n  \"name\": \"Google User\",\n  \"picture\": \"https://lh3.googleusercontent.com/a/demo-user\",\n  \"email_verified\": true\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/auth/google",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "auth",
                                                                "google"
                                                        ]
                                                },
                                                "description": "Create a new user from Google OAuth or link to existing user.\n\nBehavior:\n- If google_id exists: Return existing user\n- If email exists: Link Google to existing account\n- Otherwise: Create new user\n\nThis endpoint is typically called by the Auth Tokens service after validating the Google token.\n\nReturns complete user profile including:\n- user_id, username, email\n- status, scopes\n- is_new_user, email_verified"
                                        }
                                },
                                {
                                        "name": "Get User by Google ID",
                                        "request": {
                                                "method": "GET",
                                                "header": [],
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/auth/google/user/{{google_id}}",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "auth",
                                                                "google",
                                                                "user",
                                                                "{{google_id}}"
                                                        ]
                                                },
                                                "description": "Retrieve user information by Google ID"
                                        }
                                }
                        ]
                },
                {
                        "name": "Service Registration",
                        "item": [
                                {
                                        "name": "Register New Service",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    pm.environment.set('service_id', response.service_id);",
                                                                        "    pm.environment.set('consumer_key', response.consumer_key);",
                                                                        "    pm.environment.set('consumer_secret', response.consumer_secret);",
                                                                        "    console.log('Service registered:', response.service_id);",
                                                                        "    console.log('⚠️ IMPORTANT: Save consumer_secret - it won\\'t be shown again!');",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "method": "POST",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"service_id\": \"my-service-{{$timestamp}}\",\n  \"service_name\": \"My Application\",\n  \"description\": \"My application description\",\n  \"primary_contact_name\": \"John Doe\",\n  \"admin_email\": \"admin@myapp.com\",\n  \"phone_number\": \"+1234567890\",\n  \"scopes\": [\"profile:read\", \"data:read\"],\n  \"scope_justifications\": {\n    \"profile:read\": \"Need to read user profiles for display\",\n    \"data:read\": \"Need to read user data for analytics\"\n  }\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/service/register",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "service",
                                                                "register"
                                                        ]
                                                },
                                                "description": "Register a new service and receive OAuth credentials.\n\nValid Scopes:\n- profile:read - Read user profiles\n- data:read - Read user data\n- data:write - Write user data  \n- admin:full - Full admin access\n\nReturns:\n- service_id\n- consumer_key (public)\n- consumer_secret (private - store securely!)\n- scopes"
                                        }
                                },
                                {
                                        "name": "Validate Service Credentials",
                                        "request": {
                                                "method": "POST",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"service_id\": \"{{service_id}}\",\n  \"consumer_key\": \"{{consumer_key}}\",\n  \"consumer_secret\": \"{{consumer_secret}}\"\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/service/validate-credentials",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "service",
                                                                "validate-credentials"
                                                        ]
                                                },
                                                "description": "Validate service credentials (consumer_key and consumer_secret).\n\nUse credentials from service registration.\n\nReturns:\n- valid: boolean\n- service_id\n- scopes\n- message"
                                        }
                                },
                                {
                                        "name": "Get Service Status",
                                        "request": {
                                                "method": "GET",
                                                "header": [],
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/service/{{service_id}}/status",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "service",
                                                                "{{service_id}}",
                                                                "status"
                                                        ]
                                                },
                                                "description": "Get the status of a registered service"
                                        }
                                },
                                {
                                        "name": "Update Service",
                                        "request": {
                                                "method": "PUT",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"service_name\": \"Updated Service Name\",\n  \"description\": \"Updated description\",\n  \"primary_contact_name\": \"Jane Doe\",\n  \"admin_email\": \"newadmin@myapp.com\"\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/service/{{service_id}}/update",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "service",
                                                                "{{service_id}}",
                                                                "update"
                                                        ]
                                                },
                                                "description": "Update service information"
                                        }
                                }
                        ]
                },
                {
                        "name": "Internal APIs",
                        "item": [
                                {
                                        "name": "Get User by ID (Internal)",
                                        "request": {
                                                "method": "GET",
                                                "header": [],
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/internal/v1/users/{{user_id}}",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "internal",
                                                                "v1",
                                                                "users",
                                                                "{{user_id}}"
                                                        ]
                                                },
                                                "description": "Internal endpoint to get user by ID (UUID format required)"
                                        }
                                }
                        ]
                },
                {
                        "name": "Complete Service Registration Flow",
                        "item": [
                                {
                                        "name": "Step 1: Register Service",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    pm.environment.set('service_id', response.service_id);",
                                                                        "    pm.environment.set('consumer_key', response.consumer_key);",
                                                                        "    pm.environment.set('consumer_secret', response.consumer_secret);",
                                                                        "    console.log('✅ Step 1 Complete: Service registered');",
                                                                        "    console.log('Service ID:', response.service_id);",
                                                                        "    console.log('Consumer Key:', response.consumer_key);",
                                                                        "    console.log('Next: Run Step 2 to validate credentials');",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "method": "POST",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"service_id\": \"demo-app-{{$timestamp}}\",\n  \"service_name\": \"Demo Application\",\n  \"description\": \"Demo service for testing\",\n  \"primary_contact_name\": \"Demo Admin\",\n  \"admin_email\": \"admin@demo.com\",\n  \"scopes\": [\"profile:read\", \"data:read\", \"data:write\"],\n  \"scope_justifications\": {\n    \"profile:read\": \"Read user profiles for personalization\",\n    \"data:read\": \"Read user data for analytics\",\n    \"data:write\": \"Update user preferences\"\n  }\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/service/register",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "service",
                                                                "register"
                                                        ]
                                                },
                                                "description": "STEP 1: Register a new service and receive OAuth credentials"
                                        }
                                },
                                {
                                        "name": "Step 2: Validate Credentials",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    console.log('✅ Step 2 Complete: Credentials validated');",
                                                                        "    console.log('Valid:', response.valid);",
                                                                        "    console.log('Scopes:', response.scopes);",
                                                                        "    console.log('🎉 Service registration flow successful!');",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "method": "POST",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"service_id\": \"{{service_id}}\",\n  \"consumer_key\": \"{{consumer_key}}\",\n  \"consumer_secret\": \"{{consumer_secret}}\"\n}"
                                                },
                                                "url": {
                                                        "raw": "{{user_mgmt_base_url}}/api/v1/service/validate-credentials",
                                                        "host": [
                                                                "{{user_mgmt_base_url}}"
                                                        ],
                                                        "path": [
                                                                "api",
                                                                "v1",
                                                                "service",
                                                                "validate-credentials"
                                                        ]
                                                },
                                                "description": "STEP 2: Validate the credentials from Step 1"
                                        }
                                }
                        ],
                        "description": "Complete flow to register a service and validate credentials.\n\nRun in order:\n1. Register Service - Gets credentials\n2. Validate Credentials - Confirms they work"
                }
        ],
