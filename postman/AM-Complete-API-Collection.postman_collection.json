    {
      "name": "2. User Registration & Activation",
      "item": [
        {
          "name": "Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"user_id\", jsonData.user_id);",
                  "    pm.test(\"User registered successfully\", function() {",
                  "        pm.expect(jsonData).to.have.property('user_id');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser{{$timestamp}}@example.com\",\n  \"password\": \"SecurePassword123!\",\n  \"full_name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{user_url}}/api/v1/auth/register",
              "host": ["{{user_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new user account"
          },
          "response": []
        },
        {
          "name": "Activate User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{user_url}}/api/v1/users/{{user_id}}/status",
              "host": ["{{user_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}", "status"]
            },
            "description": "Activate a registered user (change status from pending_activation to active)"
          },
          "response": []
        },
        {
          "name": "Get User Status by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{user_url}}/api/v1/users/{{user_id}}/status",
              "host": ["{{user_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}", "status"]
            },
            "description": "Retrieve user information and status by ID"
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Authentication & Login",
      "item": [
        {
          "name": "Login - Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"access_token\", jsonData.access_token);",
                  "    pm.test(\"Login successful\", function() {",
                  "        pm.expect(jsonData).to.have.property('access_token');",
                  "        pm.expect(jsonData.token_type).to.equal('bearer');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser@example.com\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/api/v1/tokens",
              "host": ["{{auth_url}}"],
              "path": ["api", "v1", "tokens"]
            },
            "description": "Login and obtain JWT access token. Token is valid for 30 minutes."
          },
          "response": []
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"token\": \"{{access_token}}\"}"
            },
            "url": {
              "raw": "{{auth_url}}/api/v1/validate",
              "host": ["{{auth_url}}"],
              "path": ["api", "v1", "validate"]
            },
            "description": "Validate a JWT token. Pass the token in the request body.\n\n**Response:**\n```json\n{\n  \"valid\": true,\n  \"user_id\": \"...\",\n  \"username\": \"...\",\n  \"email\": \"...\",\n  \"type\": \"user\",\n  \"scopes\": [\"read\", \"write\"],\n  \"expires_at\": \"...\",\n  \"message\": \"Token is valid\"\n}\n```"
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Password Reset Feature",
      "item": [
        {
          "name": "Step 1 - Request Password Reset",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Reset request accepted\", function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\"\n}"
            },
            "url": {
              "raw": "{{user_url}}/api/v1/request-reset",
              "host": ["{{user_url}}"],
              "path": ["api", "v1", "request-reset"]
            },
            "description": "Request a password reset for a user. Returns success message regardless of whether email exists (security feature).\n\n✅ Development Mode: Token is returned in `reset_token` field - copy and use it directly!\n❌ Production Mode: Token is only sent via email, `reset_token` will be null.\n\n**Response includes:**\n- success: true/false\n- message: Status message\n- reset_token: The token to use (development only, null in production)"
          },
          "response": []
        },
        {
          "name": "Step 2 - Validate Reset Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"token\": \"PASTE_TOKEN_FROM_LOGS_HERE\"\n}"
            },
            "url": {
              "raw": "{{user_url}}/api/v1/validate-reset-token",
              "host": ["{{user_url}}"],
              "path": ["api", "v1", "validate-reset-token"]
            },
            "description": "Validate a password reset token before allowing password change.\n\n**Simple Steps:**\n1. Run \"Step 1 - Request Password Reset\"\n2. Copy the `reset_token` from the response\n3. Paste it in the `token` field below\n4. Send this request\n\n**Response:**\n- valid: true/false\n- message: Details about token validity"
          },
          "response": []
        },
        {
          "name": "Step 3 - Confirm Password Reset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"token\": \"PASTE_TOKEN_FROM_LOGS_HERE\",\n  \"new_password\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{user_url}}/api/v1/confirm-reset",
              "host": ["{{user_url}}"],
              "path": ["api", "v1", "confirm-reset"]
            },
            "description": "Complete the password reset with the new password.\n\nPassword requirements:\n- Minimum 8 characters\n- Contains uppercase letter (A-Z)\n- Contains lowercase letter (a-z)\n- Contains digit (0-9)\n\n⚠️ After successful reset:\n- Old password will no longer work\n- New password can be used to login\n- Token will be marked as used (cannot be reused)"
          },
          "response": []
        }
      ]
    },
