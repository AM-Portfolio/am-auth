# ═══════════════════════════════════════════════════════════════
# SERVICE URLS CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# This file defines all internal service URLs
# It's linked from .env.docker using SOURCE command
# Easier to manage and switch between HTTP/HTTPS
# ═══════════════════════════════════════════════════════════════

# Protocol Configuration
SERVICE_PROTOCOL=http
USE_HTTPS=false

# ───────────────────────────────────────────────────────────────
# INTERNAL SERVICES (Python/Java/Node based)
# ───────────────────────────────────────────────────────────────

# Auth Tokens Service
AUTH_TOKENS_SERVICE_HOST=auth-tokens
AUTH_TOKENS_SERVICE_PORT=8001
AUTH_SERVICE_URL=${SERVICE_PROTOCOL}://${AUTH_TOKENS_SERVICE_HOST}:${AUTH_TOKENS_SERVICE_PORT}

# User Management Service
USER_MANAGEMENT_SERVICE_HOST=am-user-management
USER_MANAGEMENT_SERVICE_PORT=8000
USER_MANAGEMENT_URL=${SERVICE_PROTOCOL}://${USER_MANAGEMENT_SERVICE_HOST}:${USER_MANAGEMENT_SERVICE_PORT}

# Python Internal Service (Document Processing)
PYTHON_INTERNAL_SERVICE_HOST=am-python-internal-service
PYTHON_INTERNAL_SERVICE_PORT=8002
PYTHON_SERVICE_URL=${SERVICE_PROTOCOL}://${PYTHON_INTERNAL_SERVICE_HOST}:${PYTHON_INTERNAL_SERVICE_PORT}

# Java Internal Service (Reporting)
JAVA_INTERNAL_SERVICE_HOST=am-java-internal-service
JAVA_INTERNAL_SERVICE_PORT=8003
JAVA_SERVICE_URL=${SERVICE_PROTOCOL}://${JAVA_INTERNAL_SERVICE_HOST}:${JAVA_INTERNAL_SERVICE_PORT}

# ───────────────────────────────────────────────────────────────
# EXTERNAL SERVICES (Spring Boot based - from AM-Portfolio repos)
# ───────────────────────────────────────────────────────────────

# Document Processor Service (Spring Boot)
DOCUMENT_PROCESSOR_SERVICE_HOST=am-document-processor
DOCUMENT_PROCESSOR_SERVICE_PORT=8070
DOCUMENT_PROCESSOR_URL=${SERVICE_PROTOCOL}://${DOCUMENT_PROCESSOR_SERVICE_HOST}:${DOCUMENT_PROCESSOR_SERVICE_PORT}

# Portfolio Service (Spring Boot)
PORTFOLIO_SERVICE_HOST=am-portfolio
PORTFOLIO_SERVICE_PORT=8080
PORTFOLIO_URL=${SERVICE_PROTOCOL}://${PORTFOLIO_SERVICE_HOST}:${PORTFOLIO_SERVICE_PORT}

# Trade API Service (Spring Boot)
TRADE_API_SERVICE_HOST=am-trade-api
TRADE_API_SERVICE_PORT=8073
TRADE_API_URL=${SERVICE_PROTOCOL}://${TRADE_API_SERVICE_HOST}:${TRADE_API_SERVICE_PORT}

# Market Data Service (Spring Boot)
MARKET_DATA_SERVICE_HOST=am-market-data
MARKET_DATA_SERVICE_PORT=8092
MARKET_DATA_URL=${SERVICE_PROTOCOL}://${MARKET_DATA_SERVICE_HOST}:${MARKET_DATA_SERVICE_PORT}

# ───────────────────────────────────────────────────────────────
# HOW TO SWITCH PROTOCOLS
# ───────────────────────────────────────────────────────────────
# For HTTP with ports (Development):
#   SERVICE_PROTOCOL=http
#   USE_HTTPS=false
#   Result: http://auth-tokens:8001, http://am-portfolio:8080
#
# For HTTPS without ports (Production):
#   SERVICE_PROTOCOL=https
#   USE_HTTPS=true
#   Result: https://auth-tokens, https://am-portfolio
#
# For custom protocol (gRPC, etc):
#   SERVICE_PROTOCOL=grpc
#   USE_HTTPS=false
#   Result: grpc://auth-tokens:8001, grpc://am-portfolio:8070
