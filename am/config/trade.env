
# ═══════════════════════════════════════════════════════════════
# TRADE SERVICE CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# MongoDB Configuration
MONGODB_URI=mongodb://ssd2658:ssd2658@host.docker.internal:27017/am-trade?authSource=admin
MONGODB_DATABASE=am-trade
MONGODB_USERNAME=ssd2658
MONGODB_PASSWORD=ssd2658

# Redis Configuration
TRADE_REDIS_HOST=host.docker.internal
TRADE_REDIS_PORT=6379
TRADE_REDIS_PASSWORD=RedisPassword123!
TRADE_REDIS_DB=2
REDIS_HOSTNAME=host.docker.internal
REDIS_PASSWORD=RedisPassword123!
REDIS_PORT=6379

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9093
KAFKA_CONSUMER_GROUP_ID=am-trade-service

# Kafka Topics
TRADE_CREATION_TOPIC=trades.created
TRADE_EXECUTION_TOPIC=trades.executed
TRADE_SETTLEMENT_TOPIC=trades.settled
TRADE_CANCELLATION_TOPIC=trades.cancelled

# Trade Limits & Constraints
TRADE_MIN_QUANTITY=1
TRADE_MAX_QUANTITY=10000
TRADE_MIN_PRICE=0.01
TRADE_MAX_PRICE=1000000
TRADE_EXECUTION_TIMEOUT_SECONDS=30
TRADE_ORDER_MAX_PENDING=500

# Thread Pool Configuration
TRADE_THREAD_POOL_SIZE=20
TRADE_THREAD_POOL_QUEUE_CAPACITY=1000

# Retry Configuration
TRADE_RETRY_MAX_ATTEMPTS=5
TRADE_RETRY_DELAY_MS=1000

# Order Management
TRADE_ORDER_VALIDATION_ENABLED=true
TRADE_ORDER_AUDIT_ENABLED=true

# Risk Management
TRADE_RISK_CHECK_ENABLED=true
TRADE_MAX_DAILY_LOSS_PERCENT=5.0
TRADE_MAX_POSITION_SIZE_PERCENT=10.0

# Market Hours
TRADE_MARKET_OPEN_TIME=09:15
TRADE_MARKET_CLOSE_TIME=15:30
TRADE_ENFORCE_MARKET_HOURS=false

# Settlement Configuration
TRADE_SETTLEMENT_TYPE=T+2
TRADE_AUTO_SETTLEMENT_ENABLED=true

# Service Integration
TRADE_MARKET_DATA_SERVICE_URL=http://host.docker.internal:8092
TRADE_PORTFOLIO_SERVICE_URL=http://host.docker.internal:8080

# Logging Configuration
TRADE_LOG_LEVEL=INFO
TRADE_AUDIT_LOG_ENABLED=true
TRADE_AUDIT_LOG_RETENTION_DAYS=90
TRADE_COMPLIANCE_CHECK_ENABLED=true

# Application Config
AM_TRADE_MAX_RETRIES=10
AM_MARKET_DATA_API_URL=http://host.docker.internal:8092
