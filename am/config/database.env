# ═══════════════════════════════════════════════════════════════
# FEATURE / REPO SPECIFIC CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# 1. TRADE MANAGEMENT (am-trade-management)
# ───────────────────────────────────────────────────────────────
TRADE_MONGODB_URL=mongodb://ssd2658:ssd2658@host.docker.internal:27017/am-trade?authSource=admin
TRADE_MONGODB_DATABASE=am-trade
TRADE_KAFKA_SERVERS=host.docker.internal:9092

# ───────────────────────────────────────────────────────────────
# 2. PORTFOLIO SERVICE (am-portfolio)
# ───────────────────────────────────────────────────────────────
PORTFOLIO_MONGODB_URL=mongodb://ssd2658:ssd2658@host.docker.internal:27017/portfolio?authSource=admin
PORTFOLIO_MONGODB_DATABASE=portfolio
PORTFOLIO_KAFKA_SERVERS=host.docker.internal:9092

# ───────────────────────────────────────────────────────────────
# 3. DOCUMENT PROCESSOR (am-document-processor)
# ───────────────────────────────────────────────────────────────
DOCUMENT_MONGODB_URL=mongodb://ssd2658:ssd2658@host.docker.internal:27017/am-document?authSource=admin
DOCUMENT_MONGODB_DATABASE=am-document
DOCUMENT_KAFKA_SERVERS=host.docker.internal:9092

# ───────────────────────────────────────────────────────────────
# 4. MARKET DATA (am-market-data)
# ───────────────────────────────────────────────────────────────
MARKET_DATA_MONGODB_URL=mongodb://ssd2658:ssd2658@host.docker.internal:27017/am-market-data?authSource=admin
MARKET_DATA_KAFKA_SERVERS=host.docker.internal:9092
MARKET_DATA_REDIS_HOSTNAME=host.docker.internal
MARKET_DATA_REDIS_PORT=6379
MARKET_DATA_REDIS_URL=redis://:RedisPassword123!@host.docker.internal:6379/0

# ───────────────────────────────────────────────────────────────
# SHARED / LEGACY INFRASTRUCTURE
# ───────────────────────────────────────────────────────────────
# PostgreSQL (Shared Auth & User Mgmt)
POSTGRES_URL=postgresql://postgres:postgres@host.docker.internal:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/postgres
SHARD_DB_HOST=host.docker.internal
SHARD_DB_PORT=5432

# Generic Redis (if needed by other services)
REDIS_HOSTNAME=host.docker.internal
REDIS_PORT=6379
REDIS_URL=redis://:RedisPassword123!@host.docker.internal:6379/0

# Generic Kafka
KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_JAAS_CONFIG=
