# ═══════════════════════════════════════════════════════════════
# PORTFOLIO SERVICE CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# MongoDB Configuration
# ───────────────────────────────────────────────────────────────
PORTFOLIO_MONGODB_URL=mongodb://ssd2658:ssd2658@host.docker.internal:27017/portfolio?authSource=admin
PORTFOLIO_MONGODB_DATABASE=portfolio
PORTFOLIO_MONGO_COLLECTION_PREFIX=portfolio_

# ───────────────────────────────────────────────────────────────
# Kafka Configuration
# ───────────────────────────────────────────────────────────────
PORTFOLIO_KAFKA_SERVERS=host.docker.internal:9092
PORTFOLIO_KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092
PORTFOLIO_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
PORTFOLIO_KAFKA_SASL_MECHANISM=PLAIN
PORTFOLIO_KAFKA_SASL_JAAS_CONFIG=

# ───────────────────────────────────────────────────────────────
# Portfolio Topics
# ───────────────────────────────────────────────────────────────
PORTFOLIO_CREATION_TOPIC=portfolio-creation-events
PORTFOLIO_UPDATE_TOPIC=portfolio-update-events
PORTFOLIO_DELETION_TOPIC=portfolio-deletion-events
PORTFOLIO_REBALANCE_TOPIC=portfolio-rebalance-events

# ───────────────────────────────────────────────────────────────
# Portfolio Configuration
# ───────────────────────────────────────────────────────────────
PORTFOLIO_MAX_HOLDINGS=100
PORTFOLIO_MIN_INVESTMENT=1000
PORTFOLIO_REBALANCE_THRESHOLD_PERCENT=5
PORTFOLIO_CALCULATION_PRECISION=2

# ───────────────────────────────────────────────────────────────
# Cache Configuration
# ───────────────────────────────────────────────────────────────
PORTFOLIO_CACHE_ENABLED=true
PORTFOLIO_CACHE_TTL_MINUTES=30
PORTFOLIO_REDIS_HOST=host.docker.internal
PORTFOLIO_REDIS_PORT=6379
PORTFOLIO_REDIS_PASSWORD=RedisPassword123!
PORTFOLIO_REDIS_DB=1

# ───────────────────────────────────────────────────────────────
# Thread Pool Configuration
# ───────────────────────────────────────────────────────────────
PORTFOLIO_THREAD_POOL_SIZE=15
PORTFOLIO_THREAD_POOL_QUEUE_CAPACITY=150
PORTFOLIO_ASYNC_ENABLED=true

# ───────────────────────────────────────────────────────────────
# Retry Configuration
# ───────────────────────────────────────────────────────────────
PORTFOLIO_RETRY_MAX_ATTEMPTS=3
PORTFOLIO_RETRY_DELAY_MS=1000
PORTFOLIO_RETRY_BACKOFF_MULTIPLIER=2

# ───────────────────────────────────────────────────────────────
# Integration with Other Services
# ───────────────────────────────────────────────────────────────
PORTFOLIO_MARKET_DATA_SERVICE_URL=http://am-market-data:8092
PORTFOLIO_DOCUMENT_SERVICE_URL=http://am-document-processor:8070
PORTFOLIO_ENABLE_MARKET_DATA_SYNC=true
PORTFOLIO_MARKET_DATA_SYNC_INTERVAL_MINUTES=5

# ───────────────────────────────────────────────────────────────
# Analytics & Reporting
# ───────────────────────────────────────────────────────────────
PORTFOLIO_ENABLE_ANALYTICS=true
PORTFOLIO_ANALYTICS_KAFKA_TOPIC=portfolio-analytics
PORTFOLIO_REPORT_GENERATION_ENABLED=true

# ───────────────────────────────────────────────────────────────
# Service Settings
# ───────────────────────────────────────────────────────────────
PORTFOLIO_SERVICE_ID=portfolio-service
PORTFOLIO_LOG_LEVEL=INFO
PORTFOLIO_ENABLE_METRICS=true
PORTFOLIO_ENABLE_HEALTH_CHECK=true

# ───────────────────────────────────────────────────────────────
# Validation Configuration
# ───────────────────────────────────────────────────────────────
PORTFOLIO_MAX_AGE_MINUTES=60
PORTFOLIO_VALIDATION_STRICT_MODE=true
