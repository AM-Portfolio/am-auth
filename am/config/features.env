# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS & OPTIONAL FEATURES
# ═══════════════════════════════════════════════════════════════
# Toggle experimental features, beta integrations, and optional services
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# Authentication Features
# ───────────────────────────────────────────────────────────────
ENABLE_OAUTH_GOOGLE=false
ENABLE_OAUTH_GITHUB=false
ENABLE_MFA=false
ENABLE_PASSWORDLESS_AUTH=false
ENABLE_SESSION_REFRESH=true

# ───────────────────────────────────────────────────────────────
# API Features
# ───────────────────────────────────────────────────────────────
ENABLE_API_RATE_LIMITING=true
ENABLE_API_CACHING=true
ENABLE_API_VERSIONING=true
ENABLE_SWAGGER_UI=true

# ───────────────────────────────────────────────────────────────
# Monitoring & Observability
# ───────────────────────────────────────────────────────────────
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_REQUEST_TRACING=true
ENABLE_ERROR_TRACKING=true
ENABLE_APM=false

# ───────────────────────────────────────────────────────────────
# Data & Storage Features
# ───────────────────────────────────────────────────────────────
ENABLE_DATA_CACHING=true
ENABLE_EVENT_SOURCING=false
ENABLE_AUDIT_LOGGING=true

# ───────────────────────────────────────────────────────────────
# External Service Integration
# ───────────────────────────────────────────────────────────────
ENABLE_DOCUMENT_PROCESSOR=false
ENABLE_PORTFOLIO_SERVICE=false
ENABLE_TRADE_API=false
ENABLE_MARKET_DATA_SERVICE=false

# ───────────────────────────────────────────────────────────────
# Beta & Experimental Features
# ───────────────────────────────────────────────────────────────
ENABLE_BETA_FEATURES=false
ENABLE_EXPERIMENTAL_API=false
ENABLE_ANALYTICS=false
