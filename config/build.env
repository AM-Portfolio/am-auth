# ═══════════════════════════════════════════════════════════════
# BUILD & DEPLOYMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Docker build contexts, build arguments, and deployment settings
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# Repository & Build Context
# ───────────────────────────────────────────────────────────────
# Local path to AM repository root for Docker build contexts
AM_REPO_PATH=.

# ───────────────────────────────────────────────────────────────
# Docker Build Configuration
# ───────────────────────────────────────────────────────────────
DOCKER_BUILD_CONTEXT=.
DOCKER_BUILDKIT=1
DOCKER_BUILD_PROGRESS=auto

# ───────────────────────────────────────────────────────────────
# Docker Compose Configuration
# ───────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=am-portfolio
COMPOSE_FILE=docker-compose.yml
COMPOSE_IGNORE_ORPHANS=true

# ───────────────────────────────────────────────────────────────
# Image Tagging & Versioning
# ───────────────────────────────────────────────────────────────
# Docker registry (empty for local, set to registry URL for remote)
DOCKER_REGISTRY=
IMAGE_TAG=latest
IMAGE_VERSION=1.0.0

# ───────────────────────────────────────────────────────────────
# Deployment Environment
# ───────────────────────────────────────────────────────────────
DEPLOYMENT_ENV=development
ENVIRONMENT=development

# ───────────────────────────────────────────────────────────────
# Resource Limits (for docker-compose and orchestration)
# ───────────────────────────────────────────────────────────────
CPU_LIMIT=2
MEMORY_LIMIT=2g
