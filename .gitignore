# Distribution / packaging
# .Python is common for python, eggs etc
.Python
# build/ is common for many languages, but we want to keep am_diagnostic_ui/lib etc
# So we ignore build/ at root but specifically NOT in submodules if they are not supposed to be ignored
# Actually, build/ is usually safe to ignore globally except in specific cases.
# But Flutter uses build/ a lot.
# Let's be more specific.
# build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# lib/ is a common name, we should only ignore it if it's a build/dep folder
# lib/  <-- This was blocking am_diagnostic_ui/lib
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

