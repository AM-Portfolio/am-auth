{
	"info": {
		"_postman_id": "12345678-1234-1234-1234-123456789012",
		"name": "AM Authentication System - Complete Test Suite",
		"description": "Complete test suite for AM Authentication System\n\n🎯 QUICK START:\n1. Run requests in order from 'Authentication Flow' folder\n2. ⚠️ IMPORTANT: After registration, you MUST activate the user (step 2)\n3. Tokens are automatically saved to environment variables\n4. Internal service requests will FAIL from Postman (network isolation working!)\n\n🔒 SECURITY ARCHITECTURE:\n- Two-layer security: Network Isolation + JWT Authentication\n- Internal services (ports 8002, 8003) are NOT externally accessible\n- Service tokens required for internal service communication\n- All 8/8 security tests passing ✅\n\n📝 TESTING:\n- Use generate_token.py script to create fresh tokens\n- Use test_security.sh to run comprehensive security tests\n- Internal services can only be accessed from within Docker network",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "🔐 Authentication Flow",
			"item": [
				{
					"name": "1. Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201 || pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('test_email', response.email || 'testuser@example.com');",
									"    console.log('✅ User registered:', response.email);",
									"    console.log('⚠️  Remember: User needs to be activated before login!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"testpass123\",\n  \"phone_number\": \"+1234567890\"\n}"
						},
						"url": {
							"raw": "http://localhost:8000/api/v1/auth/register",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8000",
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						},
						"description": "Register a new user account in User Management service"
					},
					"response": []
				},
				{
					"name": "2. Activate User Account",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    console.log('✅ User account activated successfully');",
									"    console.log('✅ Ready to login');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"active\",\n  \"reason\": \"Email verification completed\"\n}"
						},
						"url": {
							"raw": "http://localhost:8000/api/v1/users/email/testuser@example.com/status",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8000",
							"path": [
								"api",
								"v1",
								"users",
								"email",
								"testuser@example.com",
								"status"
							]
						},
						"description": "⚠️ REQUIRED STEP: Activate user account after registration before login"
					},
					"response": []
				},
				{
					"name": "3. User Login (Get JWT Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('user_access_token', response.access_token);",
									"    pm.environment.set('user_id', response.user_id);",
									"    console.log('User token saved:', response.access_token.substring(0, 50) + '...');",
									"    console.log('User ID:', response.user_id);",
									"} else {",
									"    console.log('Login failed:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "testuser@example.com",
									"type": "text"
								},
								{
									"key": "password",
									"value": "testpass123",
									"type": "text"
								},
								{
									"key": "grant_type",
									"value": "password",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "http://localhost:8001/api/v1/tokens/oauth",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8001",
							"path": [
								"api",
								"v1",
								"tokens",
								"oauth"
							]
						},
						"description": "Login via Auth Tokens service and get JWT access token (automatically saved to environment)"
					},
					"response": []
				},
				{
					"name": "4. Validate Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{user_access_token}}\"\n}"
						},
						"url": {
							"raw": "http://localhost:8001/api/v1/validate",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8001",
							"path": [
								"api",
								"v1",
								"validate"
							]
						},
						"description": "Validate JWT token and get user information"
					},
					"response": []
				},
				{
					"name": "5. Generate Service Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    // Response uses 'access_token' not 'service_token'",
									"    pm.environment.set('service_token', response.access_token);",
									"    console.log('✅ Service token saved:', response.access_token.substring(0, 50) + '...');",
									"    console.log('Service ID:', response.service_id);",
									"    console.log('Permissions:', response.permissions);",
									"    console.log('Expires in:', response.expires_in, 'seconds');",
									"} else {",
									"    console.log('❌ Service token generation failed:', pm.response.text());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{user_access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"service_id\": \"postman-test-client\",\n    \"service_name\": \"Postman Test Client\",\n    \"permissions\": [\n        \"read:documents\",\n        \"read:reports\",\n        \"write:reports\"\n    ]\n}"
						},
						"url": {
							"raw": "http://localhost:8001/api/v1/internal/service-token",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8001",
							"path": [
								"api",
								"v1",
								"internal",
								"service-token"
							]
						},
						"description": "Generate service token using user access token (automatically saved to environment)"
					},
					"response": []
				}
			],
			"description": "Complete authentication flow:\n1. Register user\n2. Activate account (REQUIRED before login)\n3. Login to get JWT\n4. Validate token\n5. Generate service token for internal services\n\n⚠️ NOTE: Step 2 (Activate Account) is REQUIRED after registration!"
		},
